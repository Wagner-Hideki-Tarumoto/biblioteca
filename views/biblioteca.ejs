<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Conecta FATEC Registro - Módulo Biblioteca</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="text-gray-800 antialiased bg-gray-100 min-h-screen flex flex-col">

    <!-- HEADER SUPERIOR (Vermelho Oficial Conecta) -->
    <header class="bg-[#b91c1c] text-white px-6 py-3.5 flex justify-between items-center shadow-md z-40">
        <div class="flex items-center gap-2 font-bold text-xl tracking-wide">
            <i class="fa-solid fa-share-nodes text-white text-2xl mr-1"></i>
            <span>Conecta</span>
        </div>
        <div class="text-sm font-medium">
            Olá, Thiago Silva! <span class="text-xs text-red-200 ml-2">| RA: 2420482311002</span>
        </div>
    </header>

    <!-- CONTAINER PRINCIPAL DO LAYOUT (Divide em Sidebar + Conteúdo) -->
    <div class="flex flex-1 flex-col md:flex-row">
        
        <!-- SIDEBAR (BARRA LATERAL) PADRÃO OFICIAL CONECTA -->
        <aside class="w-full md:w-64 bg-[#334155] text-slate-200 flex flex-col justify-between p-4 min-h-[300px] md:min-h-[calc(100vh-56px)] shadow-lg select-none">
            <div class="space-y-6">
                <!-- Links de Navegação Oficiais do Sistema -->
                <nav class="space-y-1 text-sm font-medium">
                    
                    <button onclick="navegarPara('tela-home')" class="w-full flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-slate-700/50 transition text-left">
                        <div class="flex items-center gap-3">
                            <i class="fa-solid fa-user-graduate text-slate-400 w-5 text-base"></i>
                            <span>Academies</span>
                        </div>
                        <i class="fa-solid fa-arrow-up-right-from-square text-[10px] text-slate-400"></i>
                    </button>

                    <button class="w-full flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-slate-700/50 transition text-left">
                        <div class="flex items-center gap-3">
                            <i class="fa-solid fa-calendar-days text-slate-400 w-5 text-base"></i>
                            <span>Eventos</span>
                        </div>
                        <i class="fa-solid fa-chevron-down text-xs text-slate-400"></i>
                    </button>

                    <!-- Módulo da Biblioteca dentro de Extensão -->
                    <button onclick="navegarPara('tela-hub')" class="w-full flex items-center justify-between px-3 py-2.5 rounded-lg bg-slate-700/40 text-white font-semibold transition text-left">
                        <div class="flex items-center gap-3">
                            <i class="fa-solid fa-award text-slate-300 w-5 text-base"></i>
                            <span>Extensão (Biblioteca)</span>
                        </div>
                        <i class="fa-solid fa-chevron-down text-xs text-slate-300"></i>
                    </button>

                    <button class="w-full flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-slate-700/50 transition text-left">
                        <div class="flex items-center gap-3">
                            <i class="fa-solid fa-lightbulb text-slate-400 w-5 text-base"></i>
                            <span>Projetos <span class="text-[10px] text-slate-400 font-normal italic">(beta)</span></span>
                        </div>
                        <i class="fa-solid fa-chevron-down text-xs text-slate-400"></i>
                    </button>

                    <button class="w-full flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-slate-700/50 transition text-left">
                        <div class="flex items-center gap-3">
                            <i class="fa-solid fa-graduation-cap text-slate-400 w-5 text-base"></i>
                            <span>QTE <span class="text-[10px] text-slate-400 font-normal italic">(beta)</span></span>
                        </div>
                        <i class="fa-solid fa-chevron-down text-xs text-slate-400"></i>
                    </button>

                    <button class="w-full flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-slate-700/50 transition text-left">
                        <div class="flex items-center gap-3">
                            <i class="fa-solid fa-terminal text-slate-400 w-5 text-base"></i>
                            <span>Práticas <span class="text-[10px] text-slate-400 font-normal italic">(beta)</span></span>
                        </div>
                        <i class="fa-solid fa-chevron-down text-xs text-slate-400"></i>
                    </button>

                    <button onclick="alert('Fazendo logout do Conecta...')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-red-900/30 hover:text-red-300 transition text-left mt-4">
                        <i class="fa-solid fa-right-from-bracket text-slate-400 w-5 text-base"></i>
                        <span>Sair</span>
                    </button>

                </nav>

                <!-- Simuladores do Hackathon integrados de forma limpa abaixo -->
                <div class="border-t border-slate-700/60 pt-4">
                    <span class="text-[10px] uppercase tracking-wider text-slate-400 block mb-2 font-bold px-3">Dev Simuladores</span>
                    <nav class="space-y-0.5 text-xs">
                        <button onclick="navegarPara('tela-hub')" class="w-full flex items-center gap-2 px-3 py-1.5 rounded hover:bg-slate-700 text-left text-slate-300">
                            <i class="fa-solid fa-chart-pie w-4"></i> Dashboard
                        </button>
                        <button onclick="navegarPara('tela-acervo')" class="w-full flex items-center gap-2 px-3 py-1.5 rounded hover:bg-slate-700 text-left text-slate-300">
                            <i class="fa-solid fa-book-open w-4"></i> Ver Acervo MVC
                        </button>
                        <button onclick="navegarPara('tela-totem-qr')" class="w-full flex items-center gap-2 px-3 py-1.5 rounded hover:bg-slate-700 text-left text-amber-400">
                            <i class="fa-solid fa-qrcode w-4"></i> 8. Totem QR
                        </button>
                        <button onclick="navegarPara('tela-vigilante')" class="w-full flex items-center gap-2 px-3 py-1.5 rounded hover:bg-slate-700 text-left text-red-400">
                            <i class="fa-solid fa-shield-halved w-4"></i> 10. Vigilante
                        </button>
                        <button onclick="navegarPara('tela-echo')" class="w-full flex items-center gap-2 px-3 py-1.5 rounded hover:bg-slate-700 text-left text-cyan-400">
                            <i class="fa-solid fa-circle-dot w-4"></i> 14. Echo Show
                        </button>
                    </nav>
                </div>
            </div>

            <!-- LOGO DA FATEC NO RODAPÉ DA SIDEBAR -->
            <div class="pt-4 pb-2 text-center border-t border-slate-700/60">
                <div class="text-white font-black text-2xl tracking-tight leading-none">Fatec</div>
                <div class="text-[10px] text-slate-400 uppercase tracking-widest mt-0.5">Registro</div>
            </div>
        </aside>

        <!-- ÁREA DE CONTEÚDO PRINCIPAL (Dinamizada pelos IDs das Telas) -->
        <main class="flex-1 p-6 bg-slate-50">
            
            <!-- TELA: ECHO SHOW (Aparece ativa com base no seu print atual) -->
            <div id="tela-echo" class="screen-view space-y-6">
                <div class="max-w-xl mx-auto bg-[#0b1329] text-white p-6 rounded-2xl border border-slate-800 shadow-2xl relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1.5 bg-cyan-500"></div>
                    <div class="flex justify-between items-center text-xs text-cyan-400 font-bold tracking-wide uppercase mb-4">
                        <span><i class="fa-solid fa-comment-dots mr-1.5"></i> Alexa Consulta em Tempo Real</span>
                        <span class="opacity-60">Echo Show 8</span>
                    </div>
                    
                    <div class="text-center py-6 space-y-4">
                        <h3 class="text-xl font-bold text-slate-100">Como posso ajudar na Biblioteca?</h3>
                        <p class="text-xs text-slate-400">Tente dizer comandos como estes no balcão:</p>
                    </div>

                    <div class="space-y-2.5 max-w-md mx-auto">
                        <div class="bg-slate-900/80 p-3.5 rounded-xl border border-slate-800 text-xs text-cyan-300 italic font-medium">
                            "Alexa, o livro Java para Iniciantes está disponível?"
                        </div>
                        <div class="bg-slate-900/80 p-3.5 rounded-xl border border-slate-800 text-xs text-cyan-300 italic font-medium">
                            "Alexa, onde fica o livro de Banco de Dados?"
                        </div>
                    </div>
                </div>
            </div>

            <!-- TELA: HOME -->
            <div id="tela-home" class="screen-view hidden space-y-4">
                <div class="border-b pb-4">
                    <h2 class="text-3xl font-semibold text-slate-800 tracking-tight">Bem-vindo ao Conecta</h2>
                    <p class="text-slate-500 text-sm mt-1">Comunidade e universidade conectados.</p>
                </div>
                <div class="bg-white p-5 rounded-xl shadow-sm border border-slate-200 max-w-md">
                    <span class="bg-slate-100 text-slate-700 text-xs px-2.5 py-1 rounded-md font-medium"><i class="fa-solid fa-globe mr-1"></i> Para toda comunidade</span>
                    <h3 class="font-bold text-lg text-slate-800 mt-4 mb-2">Módulo Biblioteca FATEC</h3>
                    <p class="text-xs text-slate-600 mb-4 leading-relaxed">Consulte a disponibilidade de livros, localizações de estantes e faça reservas com integração RFID.</p>
                    <button onclick="navegarPara('tela-hub')" class="bg-[#b91c1c] text-white px-4 py-2 rounded-lg font-bold text-xs hover:bg-red-800 transition">Acessar Painel</button>
                </div>
            </div>

            <!-- TELA: HUB DASHBOARD -->
            <div id="tela-hub" class="screen-view hidden space-y-6">
                <div>
                    <h2 class="text-2xl font-bold text-slate-800">Painel de Controle Interno</h2>
                    <p class="text-xs text-slate-500">Mapeamento do Ecossistema</p>
                </div>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div class="bg-white p-4 rounded-xl shadow-sm border border-l-4 border-red-600">
                        <p class="text-[10px] uppercase font-bold text-slate-400">Total no Acervo</p>
                        <p class="text-xl font-black text-slate-800"><%= livros.length %> Livros</p>
                    </div>
                </div>
                <button onclick="navegarPara('tela-acervo')" class="bg-[#334155] text-white text-xs font-bold px-4 py-2 rounded-lg hover:bg-slate-800 transition shadow">Ir Para o Acervo de Livros</button>
            </div>

            <!-- TELA: ACERVO -->
            <div id="tela-acervo" class="screen-view hidden space-y-6">
                <div>
                    <h3 class="text-xl font-bold text-slate-800">Acervo Universitário</h3>
                    <p class="text-xs text-slate-500">Dados dinâmicos renderizados via padrão arquitetural MVC</p>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% if(livros.length === 0) { %>
                        <p class="text-slate-500 text-xs col-span-3">Nenhum registro encontrado.</p>
                    <% } else { %>
                        <% livros.forEach(function(livro) { %>
                            <div class="bg-[#1e293b] text-white rounded-2xl shadow-md border border-slate-700 flex flex-col justify-between overflow-hidden group hover:shadow-xl transition duration-300">
                                <div class="p-5 space-y-4">
                                    <div class="flex justify-between items-start">
                                        <span class="<%= livro.status === 'Disponível' ? 'bg-green-700' : 'bg-slate-600' %> text-white text-[10px] font-bold px-2.5 py-1 rounded-md uppercase tracking-wider"><%= livro.status %></span>
                                        <span class="text-[10px] text-slate-400 font-mono"><%= livro.rfid %></span>
                                    </div>
                                    <div>
                                        <p class="text-xs text-amber-400 font-bold uppercase tracking-wide mb-1"><%= livro.categoria %></p>
                                        <h4 class="font-bold text-lg text-white leading-tight group-hover:text-amber-300 transition"><%= livro.titulo %></h4>
                                        <p class="text-xs text-slate-400 mt-1">Por: <%= livro.autor %></p>
                                    </div>
                                </div>
                                <div class="bg-slate-900/60 p-4 border-t border-slate-800 flex justify-between items-center text-xs">
                                    <span class="text-amber-200 font-medium"><i class="fa-solid fa-map-pin mr-1 text-red-500"></i> <%= livro.local %></span>
                                    <button onclick="alert('Requisição enviada ao Controller para: <%= livro.titulo %>')" class="bg-red-700 text-white font-bold px-3 py-1.5 rounded hover:bg-red-600 transition text-[11px]">Reservar</button>
                                </div>
                            </div>
                        <% }); %>
                    <% } %>
                </div>
            </div>

            <!-- TELA: TOTEM QR -->
            <div id="tela-totem-qr" class="screen-view hidden">
                <div class="max-w-md mx-auto bg-slate-900 text-white p-6 rounded-2xl border border-slate-800 text-center space-y-4 shadow-xl">
                    <h3 class="text-sm font-bold text-red-500 uppercase tracking-widest">Totem Autoatendimento</h3>
                    <i class="fa-solid fa-qrcode text-6xl text-white block animate-pulse"></i>
                    <p class="text-xs text-slate-400">Integração do hardware de validação de QR Code acadêmico.</p>
                </div>
            </div>

            <!-- TELA: VIGILANTE -->
            <div id="tela-vigilante" class="screen-view hidden">
                <div class="bg-white p-5 rounded-xl border-l-4 border-red-600 shadow-sm">
                    <h3 class="font-bold text-slate-800"><i class="fa-solid fa-shield-halved text-red-600 mr-2"></i>Antena de Segurança Portal</h3>
                    <p class="text-xs text-slate-500 mt-1">Conexão ativa com o barramento MQTT para monitoramento de tags RFID.</p>
                </div>
            </div>

        </main>
    </div>

    <!-- FOOTER INFERIOR -->
    <footer class="bg-white border-t border-slate-200 py-3 text-center text-[11px] text-slate-400 z-40">
        <p>© 2026 Conecta FATEC Registro • Desenvolvido por FATEC Registro • Versão MVC 1.5.2-rc2</p>
    </footer>

    <!-- ROTEAMENTO INTERNO SUAVE -->
    <script>
        function navegarPara(idTela) {
            const telas = document.querySelectorAll('.screen-view');
            telas.forEach(tela => tela.classList.add('hidden'));
            
            const telaAlvo = document.getElementById(idTela);
            if (telaAlvo) {
                telaAlvo.classList.remove('hidden');
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }
    </script>
</body>
</html>